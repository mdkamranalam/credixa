# ==========================================
# Credixa Ecosystem .gitignore
# ==========================================

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
backend-gateway/logs/

# Runtime & Process Data
pids/
*.pid
*.seed
*.pid.lock
*.state

# Operating System & Filesystem
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
Thumbs.db

# Node.js / JavaScript / TypeScript
node_modules/
dist/
build/
.npm/
.eslintcache
*.tsbuildinfo

# Coverage & Testing
coverage/
.nyc_output/
.pytest_cache/
htmlcov/
.coverage
*.lcov

# Environment Variables & Secrets
.env
.env.*
!.env.example
!.env.template
risk-engine/env/

# Python / Machine Learning / FastAPI
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
*.egg-info/
.eggs/
.mypy_cache/
.ruff_cache/
*.ipynb_checkpoints/

# Vite / React Frontend
frontend/dist/
frontend/dist-ssr/

# Project Specific Runtime & Uploads
backend-gateway/uploads/
database/data/

# Machine Learning Artifacts (Ignore generic pickles, keep core models)
*.pkl
!risk-engine/risk_model.pkl
!risk-engine/scaler.pkl

# IDE & Editor Directories
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln

# AI & Agent Tooling
.agent/
assist.md
CLAUDE.md

# Generated Knowledge Graphs
graphify-out/
.graphifyignore

# Docs
private_docs/
TESTS.md
Credixa_Testing_Procedure.pdf

# Others
generate_procedure_pdf.py
