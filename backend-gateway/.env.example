# Environment variables for the backend gateway
PORT=3000

# Database configuration
DB_USER=credixa_admin
DB_HOST=localhost
DB_NAME=credixa_db
DB_PASSWORD=your_secure_database_password_here
DB_PORT=5432

# Risk engine configuration
RISK_ENGINE_URL=http://localhost:8000/analyze-statement

# Shared secret used by the backend to authenticate against the risk engine.
# Must match the RISK_ENGINE_API_KEY set in the risk engine's own environment.
# Generate with: openssl rand -hex 32
RISK_ENGINE_API_KEY=your_secure_risk_engine_api_key_here

# JWT secret key (REQUIRED - change this in production)
# Generate with: openssl rand -hex 32
JWT_SECRET=your_secure_jwt_secret_here

# AES-256-GCM encryption key for PII fields (Aadhaar, PAN).
# Must be a 64-character hex string (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_64_char_hex_encryption_key_here

# Frontend URL (used for CORS allow-list)
FRONTEND_URL=http://localhost:5173